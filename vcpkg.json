{
  "version-string": "0.1.0",
  "description": "Structured Illumination Reconstruction and Image Utility Suite",
  "dependencies": [
    "eigen3",
    "tiff",
    "fftw3",
    {
      "name": "imgui",
      "features": [
        "docking-experimental",
        "opengl3-binding",
        "sdl3-binding"
      ]
    },
    {
      "name": "sdl3",
      "features": ["dbus"],
      "platform": "linux"
    }
  ],
  "features": {
    "testing": {
      "description": "Build and run tests",
      "dependencies": ["catch2"]
    },
    "python-bindings": {
      "description": "Build Python bindings",
      "dependencies": [{"name":"nanobind", "version>=": "2.12.0"}]
    }
  }
}